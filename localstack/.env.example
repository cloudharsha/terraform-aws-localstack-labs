# LocalStack environment configuration
# Copy this file to .env and adjust as needed

# AWS region to emulate
AWS_DEFAULT_REGION=us-east-1

# Fake credentials — LocalStack accepts any non-empty value
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Comma-separated list of AWS services to enable
# Leave blank to enable all services (Pro feature); list specific ones for Community edition
SERVICES=s3,iam,ec2,lambda,dynamodb,sqs,sns,sts,cloudwatch,logs

# Set to 1 for verbose container logs
DEBUG=0

# Set to 1 to persist state between container restarts (requires LocalStack Pro)
PERSISTENCE=0

# Lambda execution driver: "docker" recommended for local dev
LAMBDA_EXECUTOR=docker

# Volume directory on host for LocalStack data persistence
LOCALSTACK_VOLUME_DIR=./volume
